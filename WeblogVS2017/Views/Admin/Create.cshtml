@model WeblogVS2017.Models.Post
@{
    ViewData["Title"] = "เพิ่มข่าวสารใหม่";
}

<div style="background: white; padding: 4rem 0 6rem;">
    <div class="container" style="max-width: 800px;">
        <nav style="margin-bottom: 2rem;">
            <a asp-action="Dashboard" style="color: var(--gray); text-decoration: none; font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-arrow-left"></i> กลับไปแผงควบคุม
            </a>
        </nav>

        <h1 style="font-size: 2.25rem; font-weight: 800; color: var(--dark); margin-bottom: 3rem;">เพิ่มข่าวสารใหม่</h1>

        <form asp-action="Create" method="post" style="background: #f8fafc; padding: 3rem; border-radius: 32px; border: 1px solid #f1f5f9;">
            <div style="margin-bottom: 2rem;">
                <label style="display: block; font-weight: 700; color: var(--dark); margin-bottom: 0.75rem;">หัวข้อข่าว</label>
                <input type="text" name="Title" style="width: 100%; padding: 1rem 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; font-family: inherit;" placeholder="เช่น ประกาศวันหยุดประจำปี..." required />
            </div>

            <div style="margin-bottom: 2rem;">
                <label style="display: block; font-weight: 700; color: var(--dark); margin-bottom: 0.75rem;">สรุปย่อ</label>
                <textarea name="Summary" style="width: 100%; padding: 1rem 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; font-family: inherit; height: 100px;" placeholder="สรุปสั้นๆ สำหรับแสดงที่หน้าแรก..."></textarea>
            </div>

            <div style="margin-bottom: 2rem;">
                <label style="display: block; font-weight: 700; color: var(--dark); margin-bottom: 0.75rem;">เนื้อหาข่าว (HTML)</label>
                <textarea name="Content" style="width: 100%; padding: 1rem 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; font-family: inherit; height: 300px;" placeholder="กรอกเนื้อหาข่าวสารที่นี่..." required></textarea>
            </div>

            <div style="margin-bottom: 3rem;">
                <label style="display: block; font-weight: 700; color: var(--dark); margin-bottom: 0.75rem;">URL รูปภาพหน้าปก</label>
                <input type="text" name="ImageUrl" style="width: 100%; padding: 1rem 1.5rem; border-radius: 16px; border: 1px solid #e2e8f0; font-family: inherit;" placeholder="https://..." />
            </div>

            <button type="submit" style="width: 100%; background: var(--primary); color: white; border: none; padding: 1.25rem; border-radius: 16px; font-weight: 800; font-size: 1.1rem; cursor: pointer; transition: var(--transition);">
                <i class="fas fa-save"></i> บันทึกและเผยแพร่
            </button>
        </form>
    </div>
</div>
