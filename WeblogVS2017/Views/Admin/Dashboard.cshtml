@model IEnumerable<WeblogVS2017.Models.Post>
@{
    ViewData["Title"] = "แผงควบคุมผู้ดูแลระบบ";
}

<div style="background: white; min-height: 80vh; padding: 3rem 0;">
    <div class="container">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
            <div>
                <h1 style="font-size: 2.25rem; font-weight: 800; color: var(--dark); margin-bottom: 0.5rem;">จัดการข่าวสาร</h1>
                <p style="color: var(--gray);">ยินดีต้อนรับคุณ @Context.Session.GetString("FullName")</p>
            </div>
            <div style="display: flex; gap: 1rem;">
                <a asp-action="Create" style="background: var(--primary); color: white; padding: 0.75rem 1.5rem; border-radius: 12px; text-decoration: none; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; transition: var(--transition);">
                    <i class="fas fa-plus"></i> เพิ่มข่าวใหม่
                </a>
                <a asp-controller="Account" asp-action="Logout" style="background: #f1f5f9; color: #ef4444; padding: 0.75rem 1.5rem; border-radius: 12px; text-decoration: none; font-weight: 700; transition: var(--transition);">
                    <i class="fas fa-sign-out-alt"></i> ออกจากระบบ
                </a>
            </div>
        </div>

        <div style="background: white; border-radius: 24px; border: 1px solid #f1f5f9; overflow: hidden; box-shadow: var(--shadow);">
            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                <thead style="background: #f8fafc; border-bottom: 1px solid #f1f5f9;">
                    <tr>
                        <th style="padding: 1.25rem 2rem; font-weight: 700; color: var(--gray); font-size: 0.85rem; text-transform: uppercase;">หัวข้อข่าว</th>
                        <th style="padding: 1.25rem 2rem; font-weight: 700; color: var(--gray); font-size: 0.85rem; text-transform: uppercase;">ผู้เขียน</th>
                        <th style="padding: 1.25rem 2rem; font-weight: 700; color: var(--gray); font-size: 0.85rem; text-transform: uppercase;">วันที่สร้าง</th>
                        <th style="padding: 1.25rem 2rem; font-weight: 700; color: var(--gray); font-size: 0.85rem; text-transform: uppercase; text-align: right;">จัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr style="border-bottom: 1px solid #f1f5f9; transition: var(--transition);" onmouseover="this.style.background='#fcfdfe'" onmouseout="this.style.background='white'">
                            <td style="padding: 1.5rem 2rem;">
                                <div style="font-weight: 700; color: var(--dark); margin-bottom: 0.25rem;">@post.Title</div>
                                <div style="font-size: 0.8rem; color: var(--gray);">ID: #@post.Id</div>
                            </td>
                            <td style="padding: 1.5rem 2rem; color: var(--dark); font-weight: 600;">@(post.Author?.FullName ?? "N/A")</td>
                            <td style="padding: 1.5rem 2rem; color: var(--gray); font-size: 0.9rem;">@post.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                            <td style="padding: 1.5rem 2rem; text-align: right;">
                                <div style="display: flex; gap: 0.75rem; justify-content: flex-end;">
                                    <a asp-action="Edit" asp-route-id="@post.Id" style="width: 36px; height: 36px; background: #eff6ff; color: var(--primary-light); border-radius: 10px; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: var(--transition);">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@post.Id" method="post" onsubmit="return confirm('คุณต้องการลบข่าวนี้ใช่หรือไม่?');" style="display: inline;">
                                        <button type="submit" style="width: 36px; height: 36px; background: #fef2f2; color: #ef4444; border-radius: 10px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: var(--transition);">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (!Model.Any())
            {
                <div style="padding: 5rem 0; text-align: center;">
                    <i class="fas fa-inbox" style="font-size: 3rem; color: #e2e8f0; margin-bottom: 1.5rem;"></i>
                    <p style="color: var(--gray);">ยังไม่มีข่าวสารในระบบ</p>
                </div>
            }
        </div>
    </div>
</div>
