@model WeblogVS2017.Models.Post
@{
    ViewData["Title"] = Model.Title;
}

<div style="background: white; padding: 4rem 0 6rem;">
    <div class="container" style="max-width: 800px;">
        <nav style="margin-bottom: 2rem;">
            <a asp-action="Index" style="color: var(--gray); text-decoration: none; font-weight: 600; font-size: 0.9rem; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-chevron-left"></i> กลับไปหน้าแรก
            </a>
        </nav>

        <header style="margin-bottom: 3rem;">
            <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 1.5rem;">
                <span style="background: #eff6ff; color: var(--primary-light); padding: 0.4rem 1rem; border-radius: 50px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase;">ข่าวประกาศ</span>
                <span style="color: var(--gray); font-size: 0.9rem;"><i class="far fa-calendar-alt"></i> @Model.CreatedAt.ToString("dd MMMM yyyy")</span>
            </div>
            <h1 style="font-size: 3rem; font-weight: 900; color: var(--dark); line-height: 1.2; margin-bottom: 2rem;">@Model.Title</h1>
            <div style="display: flex; align-items: center; gap: 1rem; padding-bottom: 2rem; border-bottom: 1px solid #f1f5f9;">
                <div style="width: 48px; height: 48px; background: #f1f5f9; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--gray);">
                    <i class="fas fa-user"></i>
                </div>
                <div>
                    <div style="font-weight: 700; color: var(--dark);">@(Model.Author?.FullName ?? "ผู้ดูแลระบบ")</div>
                    <div style="font-size: 0.85rem; color: var(--gray);">ผู้เขียนบทความ</div>
                </div>
            </div>
        </header>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Title" style="width: 100%; border-radius: 32px; margin-bottom: 3rem; box-shadow: var(--shadow);">
        }

        <div style="font-size: 1.15rem; line-height: 1.8; color: #334155;">
            @Html.Raw(Model.Content)
        </div>
    </div>
</div>
